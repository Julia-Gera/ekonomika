{
  "kind": "collectionType",
  "collectionName": "news",
  "info": {
    "singularName": "news-item",
    "pluralName": "news",
    "displayName": "Новость",
    "description": "Новости со свободным бейджем"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "excerpt": {
      "type": "text"
    },
    "content": {
      "type": "richtext"
    },
    "date": {
      "type": "date"
    },
    "badge": {
      "type": "string"
    },
    "cover": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    }
  }
}
