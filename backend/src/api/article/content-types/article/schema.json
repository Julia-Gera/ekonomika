{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Статья",
    "description": "Статьи и новости"
  },
  "options": {
    "draftAndPublish": true
  },
  "config": {
    "attributes": {
      "category": {
        "hidden": true
      },
      "topicSlug": {
        "hidden": true
      }
    }
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "excerpt": {
      "type": "text"
    },
    "content": {
      "type": "richtext"
    },
    "date": {
      "type": "date"
    },
    "topic": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::article-topic.article-topic",
      "inversedBy": "articles"
    },
    "category": {
      "type": "string"
    },
    "topicSlug": {
      "type": "string"
    },
    "cover": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    }
  }
}
