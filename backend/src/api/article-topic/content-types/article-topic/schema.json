{
  "kind": "collectionType",
  "collectionName": "article_topics",
  "info": {
    "singularName": "article-topic",
    "pluralName": "article-topics",
    "displayName": "Раздел статей",
    "description": "Категории статей"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "lead": {
      "type": "text"
    },
    "body": {
      "type": "text"
    },
    "number": {
      "type": "string"
    },
    "articles": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::article.article",
      "mappedBy": "topic"
    },
    "icon": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images", "files"]
    }
  }
}
